rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Role definitions
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users Collection (PII & Profiles)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || resource.data.isPublic == true;
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Properties Collection
    match /properties/{propertyId} {
      // Anyone can read active properties
      allow read: if resource.data.status == 'active' || isAdmin() || isOwner(resource.data.ownerId);
      // Only property owners and admins can create/update
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.ownerId) || isAdmin();
    }
    
    // Bookings Collection (Escrow & Transactions)
    match /bookings/{bookingId} {
      // Only involved parties (renter, owner) and admin can read
      allow read: if isOwner(resource.data.renterId) || isOwner(resource.data.ownerId) || isAdmin();
      // Only renter can create bookings. Only admin or system can change status to 'Confirmed'
      allow create: if isOwner(request.resource.data.renterId);
      allow update: if isOwner(resource.data.renterId) || isOwner(resource.data.ownerId) || isAdmin();
    }
    
    // Messages Collection (Chat)
    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
